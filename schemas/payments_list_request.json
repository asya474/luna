{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "PaymentsListRequest",
  "type": "object",
  "required": ["wallet", "rows"],
  "additionalProperties": true,
  "properties": {
    "wallet": {
      "type": "string",
      "pattern": "^[0-9]{11}$"
    },
    "rows": {
      "type": "integer",
      "minimum": 1,
      "maximum": 50
    }
  }
}
