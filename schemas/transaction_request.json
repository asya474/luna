{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "TransactionLookupRequest",
  "type": "object",
  "required": ["transaction_id"],
  "additionalProperties": true,
  "properties": {
    "transaction_id": {
      "type": "string",
      "pattern": "^[0-9]+$"
    },
    "type": {
      "type": "string",
      "enum": ["IN", "OUT", "QIWI_CARD"]
    }
  }
}
