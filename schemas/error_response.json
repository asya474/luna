{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ApiErrorResponse",
  "type": "object",
  "additionalProperties": true,
  "properties": {
    "errorCode": { "type": "integer" },
    "description": { "type": "string" },
    "message": { "type": "string" },
    "title": { "type": "string" }
  },
  "anyOf": [
    { "required": ["errorCode"] },
    { "required": ["message"] },
    { "required": ["description"] }
  ]
}
