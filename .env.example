# QIWI Wallet Personal API credentials
# Bearer token from QIWI wallet settings (OAuth token issuance is discontinued per docs)
QIWI_API_TOKEN=your_bearer_token_here

# Wallet phone number without '+' (e.g. 79991234567)
QIWI_WALLET=79991234567

# Recipient for P2P test payment (provider 99), with or without '+'
QIWI_PAYMENT_RECIPIENT=79997654321

# API base URL (override for mocks/staging)
QIWI_BASE_URL=https://edge.qiwi.com

# Set to 'true' to skip live API calls and use fixture responses
QIWI_MOCK_MODE=false

# Request timeout in seconds
QIWI_REQUEST_TIMEOUT=30

# Playwright doc validation URL
QIWI_DOCS_URL=https://developer.qiwi.com/ru/qiwi-wallet-personal/#intro
